PORT=4000
DATABASE_URL="file:./dev.db"
JWT_SECRET="supersecret"

# AI provider: ollama | openai_compatible | groq | openrouter | gemini
AI_PROVIDER="ollama"

# Ollama settings (AI_PROVIDER=ollama)
OLLAMA_URL="http://ollama:11434/api/generate"
OLLAMA_MODEL="llama3.2:3b"

# OpenAI-compatible settings (AI_PROVIDER=openai_compatible|groq|openrouter)
LLM_API_KEY=""
LLM_BASE_URL=""
LLM_MODEL=""
OPENROUTER_APP_NAME="family-graph-enterprise-platform"
OPENROUTER_APP_URL="http://localhost:3000"

# Gemini settings (AI_PROVIDER=gemini)
GEMINI_API_KEY=""
GEMINI_ENDPOINT="https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent"
