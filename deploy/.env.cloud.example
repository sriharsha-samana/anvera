# Public domains pointing to your VM
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Required
JWT_SECRET=replace-with-a-long-random-secret

# AI provider options: ollama | openai_compatible | groq | openrouter | gemini
AI_PROVIDER=openrouter

# For openai_compatible|groq|openrouter
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=anvera

# For gemini
GEMINI_API_KEY=
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# For ollama (only if AI_PROVIDER=ollama and you add an ollama service)
OLLAMA_URL=
OLLAMA_MODEL=
